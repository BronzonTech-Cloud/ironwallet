# IronWallet Environment Variables Template

# --- Security ---
# Change this to a long, random string in production!
JWT_SECRET_KEY=supersecretkey
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Infrastructure ---
# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=ironwallet

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest

# Redis
REDIS_URL=redis://redis:6379/0

# --- Service URLs (Internal Docker Network) ---
AUTH_SERVICE_URL=http://auth-service:8000
WALLET_SERVICE_URL=http://wallet-service:8000
TRANSACTION_SERVICE_URL=http://transaction-service:8000
ADMIN_SERVICE_URL=http://admin-service:8000
